  "version": "1.0.0",
  "description": "Roompal - Property Listing & Roommate Matching Platform",
  "main": "index.js",
  "scripts": {
    "start": "cd backend && npm start",
    "dev": "cd backend && npm run dev",
    "build": "tailwindcss -i ./src/input.css -o ./dist/output.css --minify",
