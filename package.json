  },
  "homepage": "https://github.com/Dev-Sayo/roompal#readme",
  "dependencies": {
    "@tailwindcss/cli": "^4.1.18",
    "tailwindcss": "^4.1.18"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  }
